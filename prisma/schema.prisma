datasource db {
  provider = "postgresql"
  url      = env("PRISMA_DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Pattern {
  id            Int      @id @default(autoincrement())
  name          String
  gauge         String
  type          String
  yarn          String
  yarnComponent String
  note          String
  imageUrl      String?
  createdAt     DateTime @default(now())
}
